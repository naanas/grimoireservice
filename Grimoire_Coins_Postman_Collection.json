                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"userId\": \"DB_USER_UUID\",\n    \"amount\": 50000,\n    \"paymentMethod\": \"qris\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/deposit",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "deposit"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Transaction Details",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/check/:id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "check",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "TRANSACTION_UUID"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get History",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
