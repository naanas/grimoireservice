        {
            "name": "Transactions",
            "item": [
                {
                    "name": "Check Game ID",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"gameSlug\": \"mobile-legends\",\n    \"userId\": \"12345678\",\n    \"zoneId\": \"1234\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/check-id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "check-id"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Create Transaction",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"productId\": \"PRODUCT_UUID_HERE\",\n    \"userId\": \"GAME_USER_ID\",\n    \"zoneId\": \"GAME_ZONE_ID\",\n    \"paymentMethod\": \"qris\",\n    \"authUserId\": \"OPTIONAL_DB_USER_ID\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/create",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "create"
                            ]
                        }
                    },
                    "response": []
                },
