generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  PROVIDER_FAILED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phoneNumber String? @unique
  password  String?
  name      String?
  role      Role     @default(USER)
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  isVerified      Boolean   @default(false)
  verificationToken String? @unique

  transactions Transaction[]
  chatSessions ChatSession[]
  reviews Review[]

  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  image     String?   // URL to image
  brand     String?   // Grouping (e.g. "Mobile Legends", "Ragnarok")
  isActive          Boolean   @default(true)
  
  // Game Feature Config
  requiresZoneId    Boolean   @default(false)
  requiresServerId  Boolean   @default(false)
  code              String?   // Provider Code (e.g. mobile-legends)
  profitMargin      Float     @default(5.0) // Percentage (5.0 = 5%)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  products  Product[]
  reviews Review[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  sku_code      String   @unique // Code from provider (e.g. ML-5)
  name          String
  price_provider Float   // Price from Digiflazz/Apigames
  price_sell    Float    // Price to User
  category      Category @relation(fields: [categoryId], references: [id])
  categoryId    String
  group         String   @default("Top Up") // e.g. "Event", "Starlight", "Joki"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions Transaction[]

  @@map("products")
}

enum TransactionType {
  GAME_TOPUP
  DEPOSIT
}

model Transaction {
  id              String            @id @default(uuid())
  invoice         String            @unique // GRM-2024...
  user            User?             @relation(fields: [userId], references: [id])
  userId          String?           // Nullable for Guest
  guestContact    String?           // WA/Email for guest
  productId       String?
  product         Product?          @relation(fields: [productId], references: [id])
  targetId        String?           // Game ID (Nullable for Deposit)
  type            String            @default("TOPUP") // TOPUP or DEPOSIT?
  zoneId          String?           // Game Server (Nullable)
  
  amount          Float             // Total Paid (After Discount)
  adminFee        Float             @default(0)
  discountAmount  Float             @default(0)
  voucherCode     String?
  
  status          TransactionStatus @default(PENDING)
  paymentMethod   String            // QRIS, VA_BCA, etc.
  paymentUrl      String?           // URL/QR String from Ipaymu
  paymentTrxId    String?           // ID from Ipaymu
  paymentGateway  String?           // TRIPAY, IPAYMU, or BALANCE
  paymentChannel  String?           // e.g. "bca", "qris" (Saved from Callback)
  paymentNo       String?           // e.g. VA Number (Saved from Callback)
  
  providerTrxId   String?           // ID from Apigames
  providerStatus  String?           // Status from Apigames
  sn              String?           // Serial Number / Token from Provider
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("transactions")
}

model Banner {
  id        String   @id @default(uuid())
  title     String?  // Optional title for alt text or overlay
  imageUrl  String   // URL to image
  linkUrl   String?  // Optional: Redirect when clicked
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("banners")
}

enum VoucherType {
  FIXED
  PERCENTAGE
}

model Voucher {
  id          String      @id @default(uuid())
  code        String      @unique
  type        VoucherType @default(FIXED)
  amount      Float       // 10000 or 10 (if %)
  minPurchase Float       @default(0)
  maxDiscount Float?      // Max discount for % type
  stock       Int         @default(0)
  isActive    Boolean     @default(true)
  expiresAt   DateTime
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@map("vouchers")
}

model ChatSession {
  id           String   @id @default(uuid())
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?
  guestName    String?  // For guest users
  guestEmail   String? // Optional contact for guest
  sessionToken String? // Added for security
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  messages  ChatMessage[]
  
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  session   ChatSession @relation(fields: [sessionId], references: [id])
  sessionId String
  sender    Role        @default(USER) // USER or ADMIN
  content   String
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())
  
  @@map("chat_messages")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model Review {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String
  
  rating     Int      // 1-5 stars
  comment    String?  // Optional text review
  
  isApproved Boolean  @default(false) // Admin moderation
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@map("reviews")
  @@index([categoryId])
  @@index([userId])
  @@unique([userId, categoryId]) // One review per user per category
}
